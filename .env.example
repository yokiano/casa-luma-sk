# Notion API Configuration
NOTION_API_KEY=
NOTION_EVENTS_DB_ID=
NOTION_RSVPS_DB_ID=
NOTION_WAITLIST_DB_ID=

# Database
DATABASE_URL=postgres://app:app@localhost:5432/casa_luma

# Optional webhook header protection (x-webhook-token)
LOYVERSE_WEBHOOK_SECRET=

# Optional Telegram alerts for severe receipt webhook incidents
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_MESSAGE_THREAD_ID=
TELEGRAM_ALERT_TIMEOUT_MS=3000
# Optional absolute base URL to include incident links in Telegram
INCIDENT_REPORT_BASE_URL=http://localhost:5174

# Set to 1 to force a validation failure for webhook alert testing
RECEIPT_VALIDATION_FORCE_FAIL=0
