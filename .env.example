# Notion API Configuration
NOTION_API_KEY=
NOTION_EVENTS_DB_ID=
NOTION_RSVPS_DB_ID=
NOTION_WAITLIST_DB_ID=

# Database
# Production/Vercel: use Neon pooled URL for runtime.
DATABASE_URL=postgres://app:app@localhost:5432/casa_luma
# Production/Vercel: use Neon direct/unpooled URL for migrations and drizzle-kit.
DATABASE_URL_UNPOOLED=
# Optional aliases supported by runtime/migration config.
POSTGRES_URL=
POSTGRES_URL_NON_POOLING=

# Loyverse receipts ingestion/backfill
# Optional webhook header protection. Loyverse must send x-webhook-token with this value when set.
LOYVERSE_WEBHOOK_SECRET=
# Required for scripts that call the Loyverse API, including receipts:backfill and receipts:reconcile.
LOYVERSE_ACCESS_TOKEN=
# Required for backfill/reconciliation unless passed as --merchant-id.
LOYVERSE_MERCHANT_ID=
# Optional default store filter for scripts/UI helpers. Keep spelling exactly LOYVERSE_STORE_ID.
LOYVERSE_STORE_ID=

# Optional Telegram alerts for severe receipt webhook incidents
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_MESSAGE_THREAD_ID=
TELEGRAM_ALERT_TIMEOUT_MS=3000
# Optional absolute base URL to include incident links in Telegram
INCIDENT_REPORT_BASE_URL=http://localhost:5174

# Set to 1 to force a validation failure for webhook alert testing. Never enable in production.
RECEIPT_VALIDATION_FORCE_FAIL=0
